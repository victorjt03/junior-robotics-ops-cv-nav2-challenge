cat > .gitignore <<'EOF'
# ==============================================================================
# Block A: datasets & training artifacts (DO NOT COMMIT)
# ==============================================================================

block_a_cv/data/raw/
block_a_cv/data/processed/
block_a_cv/runs/
block_a_cv/**/runs/

*.pt
*.onnx
*.engine
*.tflite
*.mlmodel
*.torchscript
*.jit

*.log
*.jsonl

# ==============================================================================
# Third-party code (vendored)
# ==============================================================================
block_a_cv/third_party/yolov9/

# ==============================================================================
# Local weights (pretrained / downloaded checkpoints)
# ==============================================================================
block_a_cv/weights/

# ==============================================================================
# Python env / caches
# ==============================================================================
.venv/
venv/
.env/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.ipynb_checkpoints/

# ==============================================================================
# OS / editor
# ==============================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
EOF